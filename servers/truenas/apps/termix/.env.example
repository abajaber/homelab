# Termix stores OIDC config in its encrypted SQLite via the admin UI, so the
# compose body has no ${VAR} references today. Anything stored here is for
# external tooling that needs to talk to Termix or recall the Authentik OIDC
# client secret out-of-band. Workflow on a fresh app:
#   1. Deploy via `ansible-playbook playbooks/truenas_sync.yml -e mode=apply`.
#   2. Create an OIDC provider+application in Authentik UI for Termix:
#        Redirect URI: https://termix.bajaber.ca/users/oidc/callback
#        PKCE: disabled
#   3. Copy the client_id / client_secret into Termix admin UI -> OIDC tab.
#   4. (Optional) Record them here, then:
#        ansible-vault encrypt servers/truenas/apps/termix/.env

TERMIX_OIDC_CLIENT_ID=replace-me
TERMIX_OIDC_CLIENT_SECRET=replace-me
