# Per-app secrets file template.
#
# 1. Copy to `.env` next to compose.yml.
# 2. Replace placeholder with the real WireGuard private key from your VPN provider.
# 3. Encrypt with:  ansible-vault encrypt servers/truenas/apps/qbittorrent-vpn/.env
# 4. Edit afterwards via:  ansible-vault edit servers/truenas/apps/qbittorrent-vpn/.env
#
# References from compose.yml use ${VAR} syntax. The reconciler substitutes
# values into the compose body before sending it to TrueNAS.

WIREGUARD_PRIVATE_KEY=replace-me
