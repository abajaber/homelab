# Per-app secrets for paperless-ngx + companions.
#
# 1. Copy to `.env` next to compose.yml.
# 2. Generate strong random values for the first three keys:
#      openssl rand -hex 16    # PAPERLESS_DB_PASSWORD, PAPERLESS_REDIS_PASSWORD
#      openssl rand -hex 32    # PAPERLESS_SECRET_KEY (Django requires >=50 chars; hex 32 = 64)
# 3. Leave PAPERLESS_API_TOKEN empty for phase 1 -- mint it from the paperless
#    UI after first login (Settings -> API Tokens), then `ansible-vault edit`
#    this file and paste it in. Phase-2 apply will pick it up.
# 4. Encrypt with:  ansible-vault encrypt servers/truenas/apps/paperless-ngx/.env
# 5. Edit afterwards via:  ansible-vault edit servers/truenas/apps/paperless-ngx/.env

PAPERLESS_DB_PASSWORD=replace-me
PAPERLESS_REDIS_PASSWORD=replace-me
PAPERLESS_SECRET_KEY=replace-me
PAPERLESS_API_TOKEN=replace-me-after-first-login
