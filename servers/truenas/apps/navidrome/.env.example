# Per-app credentials for Navidrome.
#
# 1. Copy to `.env` next to compose.yml.
# 2. Fill values in.
# 3. Encrypt:  ansible-vault encrypt servers/truenas/apps/navidrome/.env
# 4. Edit afterwards via:  ansible-vault edit servers/truenas/apps/navidrome/.env

# Optional Last.fm integration (artist bios, similar-artist links). Get a
# free key at https://www.last.fm/api/account/create — leave as replace-me
# to disable.
LASTFM_APIKEY=replace-me
LASTFM_SECRET=replace-me
