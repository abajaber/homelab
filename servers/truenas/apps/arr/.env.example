# Per-app credentials notebook for the arr stack.
#
# This file is NOT consumed by compose.yml — the *arr containers each
# generate and persist their own API key in /config/config.xml on first
# start. Storing the keys here just gives external tooling (migration
# scripts, ad-hoc curls, dashboards) a single vault-encrypted source of
# truth, instead of having to ssh in and grep config.xml every time.
#
# 1. Copy to `.env` next to compose.yml.
# 2. After the apps boot the first time, read the generated keys from
#    /mnt/redsea/apps/arr/<app>/config/config.xml on TrueNAS and paste
#    them in here.
# 3. Encrypt with:  ansible-vault encrypt servers/truenas/apps/arr/.env
# 4. Edit afterwards via:  ansible-vault edit servers/truenas/apps/arr/.env
#
# Bootstrap a shell with these as env vars (used by scripts/migrate_arr_settings.py):
#   set -a; eval "$(ansible-vault view servers/truenas/apps/arr/.env)"; set +a

# SONARR_ANIME_API_KEY = the anime-tuned `sonarr` instance.
# SONARR_TV_API_KEY    = the TV-tuned `sonarr-tv` instance.
# SONARR_API_KEY is kept as a legacy alias pointing at the anime instance so
# older scripts that reference SONARR_API_KEY don't break.
SONARR_ANIME_API_KEY=replace-me
SONARR_TV_API_KEY=replace-me
SONARR_API_KEY=replace-me
RADARR_API_KEY=replace-me
LIDARR_API_KEY=replace-me
PROWLARR_API_KEY=replace-me
BAZARR_API_KEY=replace-me
