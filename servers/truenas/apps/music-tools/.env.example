# Per-app credentials for the music-tools stack.
#
# 1. Copy to `.env` next to compose.yml.
# 2. Fill values in (see post-deploy notes per key below).
# 3. Encrypt:  ansible-vault encrypt servers/truenas/apps/music-tools/.env
# 4. Edit afterwards via:  ansible-vault edit servers/truenas/apps/music-tools/.env

# Soulseek network credentials. Free signup at soulseek.org.
# Used by slskd to log into the Soulseek P2P network.
SLSKD_SLSK_USERNAME=replace-me
SLSKD_SLSK_PASSWORD=replace-me

# slskd's REST API key. Generate post-deploy in the slskd UI:
# Settings -> Authentication -> API Keys -> + Add (>=16 chars).
# Consumed by Soularr (config.ini) and Explo (env).
SLSKD_API_KEY=replace-me-min-16-chars

# Lidarr's API key. Read post-deploy from Lidarr UI:
# Settings -> General -> Security -> API Key.
# Used by external tooling (migration scripts, ad-hoc curls). Soularr
# reads its own copy from /data/config.ini, not from env.
LIDARR_API_KEY=replace-me

# Explo: ListenBrainz username (the user whose recommendations to fetch).
# Configure Navidrome to scrobble to this user before Explo will produce
# useful recommendations.
LISTENBRAINZ_USER=replace-me

# Explo: dedicated Navidrome user it logs in as via Subsonic API.
# Create the `explo` user in Navidrome admin (Settings -> Users); set its
# Subsonic password (NOT the Authentik password) and put it here.
EXPLO_NAVIDROME_USERNAME=explo
EXPLO_NAVIDROME_PASSWORD=replace-me
