# open-terminal REST API auth.
# Generate a fresh key (e.g. `openssl rand -hex 32`) and paste it below,
# then encrypt with:
#   ansible-vault encrypt servers/truenas/apps/open-terminal/.env
# Edit afterwards via:
#   ansible-vault edit servers/truenas/apps/open-terminal/.env
#
# Used by clients as `Authorization: Bearer <key>` (or X-API-Key — see /docs).
OPEN_TERMINAL_API_KEY=replace-me
