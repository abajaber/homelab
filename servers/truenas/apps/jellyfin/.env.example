# Per-app credentials notebook for Jellyfin + Jellyseerr.
#
# This file is NOT consumed by compose.yml — Jellyfin generates and persists
# its own admin credentials and API keys in /config on first start. Storing
# the keys here just gives external tooling (provisioning scripts, ad-hoc
# curls, dashboards) a single vault-encrypted source of truth.
#
# 1. Copy to `.env` next to compose.yml.
# 2. Generate an API key in Jellyfin → Dashboard → API Keys, paste it here.
# 3. Encrypt with:  ansible-vault encrypt servers/truenas/apps/jellyfin/.env
# 4. Edit afterwards via:  ansible-vault edit servers/truenas/apps/jellyfin/.env
#
# Bootstrap a shell with these as env vars:
#   set -a; eval "$(ansible-vault view servers/truenas/apps/jellyfin/.env)"; set +a

JELLYFIN_API_KEY=replace-me
JELLYSEERR_API_KEY=replace-me
