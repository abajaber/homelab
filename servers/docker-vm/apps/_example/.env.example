# Per-app secrets file template.
#
# 1. Copy to `.env` next to compose.yml in your real (enabled) app dir.
# 2. Replace placeholder values with the real ones.
# 3. Encrypt with:  ansible-vault encrypt servers/<host>/apps/<app>/.env
# 4. Edit afterwards via:  ansible-vault edit servers/<host>/apps/<app>/.env
#
# Docker Compose v2 auto-loads `.env` from the project directory at deploy
# time, so compose.yml just references ${VAR}.

EXAMPLE_PASSWORD=replace-me
EXAMPLE_API_TOKEN=replace-me
