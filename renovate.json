{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "timezone": "America/Toronto",
  "schedule": ["before 6am on monday"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"]
  },
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "docker-compose": {
    "managerFilePatterns": [
      "/servers/truenas/apps/.+/compose\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "groupName": "linuxserver",
      "automerge": true,
      "matchPackageNames": [
        "lscr.io/linuxserver/{/,}**",
        "linuxserver/{/,}**"
      ]
    },
    {
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning"
      ],
      "groupName": "immich"
    },
    {
      "matchPackageNames": ["ghcr.io/goauthentik/server"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "matchPackageNames": ["postgres", "alpine", "traefik", "valkey/valkey", "redis"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false
    }
  ]
}
